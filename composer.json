{
    "name": "westech/products-api",
    "description": "HTTP REST API",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "ext-bcmath": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "symfony/http-foundation": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/routing": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/validator": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
